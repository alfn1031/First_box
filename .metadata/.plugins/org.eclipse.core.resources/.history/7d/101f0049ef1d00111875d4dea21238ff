package com.kh.first; // 패키지 선언부 : 현재 class의 위치

	/*
	 *  여기에 쓰는 모든 건 전부 주석 (comments)
	 *  
	 *  주석은 프로그램을 실행하는대 있어 아무런 영향을 끼치지 않음!
	 *  코드르 작성한 후 작성한코드를 쉽게 이해하기 위함
	 *  주석을 달아놓아 유지보수 시간을 줄일 수 있음
	 *  
	 *   주석의 종류(오늘은 2가지만 -> 나머지 하나는 3월23일에)
	 *    
	 *  1. 한 줄 주석 (//) : 작성할 내용이 한 줄 일때 사용
	 *  "//" 이후부터 행의 끝까지 모든 내용을 주석으로 간주
	 *  
	 *  2. 여러줄 주석 ("/*~~~~~~~*") : 작성할 내용이 여러 줄일때 사용
	 *  "~~~~~~" 사이의 모든 내용을 주석으로 간주
	 */

	/*
	 * 패키지(pakege)
	 * 
	 * 소스코드를 작성할 때, 클래스를 만들어서 작업하는대
	 * 모든 클래스들을 동일한 패키지에 생성하여 관리하면 복잡하기 때문에
	 * 크래스들을 용도애 맞게 구분해서 패키지에 보관하는 것을 "권장"
	 * 
	 * 하나의 패키지 안에 여러개의 클래스들이 존재 할 수 있음
	 * 단, 동일한 이름의 크래스는 존재 할 수 없음
	 * 
	 * 권장사항
	 * 
	 * 패키지는 적어도 세 단계 이상으로 만들어 주는 것을 권장함
	 * ex) com.kh.first
	 * 
	 * com(회사이름).(프로젝트 이름/팀이름/도메인이름)
	 * 
	 */
public class HelloWorld { // 클래스 명은 HelloWorld라고 지었음 { Scoop / Block }

	public static void main(String[] args) {	
		// method : 하나의 기능 단위
		// 하나의 크래스 안에 여러 개의 메소드가 존재 할 수 있음
		// 메소드 안의 구문을 수행하고 싶다면 반드시 "호출"해야 한다!!!!!
		
		printMyName();
		System.out.print("Hello World~!"); //출력을 할 때 사용하는 기능
		//논리적인 한 문장이 끝날 때 반드시 세미콜론(;)을 붙임!!!!
		//printMyName();
	}
	
	public static void printMyName( ) { //메소드 선언!
		// 안녈하세요 제 이름은 김민수입니다. 반갑습니다~
		System.out.print("안녕하세요 제 이름은 김민수입니다. 반갑습니다~");
		
	} //메소드 영역 끝!
	
	
	
	

}
